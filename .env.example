## Supabase (frontend - ANON key only)
# URL du projet Supabase (ex: https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Clé ANON (publique) du projet Supabase
VITE_SUPABASE_ANON_KEY=

## Storage (uploads Convert)
# Nom du bucket Storage où stocker les PDFs uploadés
VITE_SUPABASE_STORAGE_BUCKET=convert-uploads

# Toggle de sécurité : si false/absent, l'app n'uploadera rien (comportement actuel)
VITE_CONVERT_UPLOADS_ENABLED=false

